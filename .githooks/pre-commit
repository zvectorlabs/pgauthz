#!/bin/sh
# Pre-commit: fmt, check, clippy. Reject commit if any step fails or fmt changed files.

set -e
cd "$(git rev-parse --show-toplevel)"

make fmt

# If fmt changed any tracked files, reject so user re-stages and commits.
if ! git diff --quiet; then
	echo "make fmt changed some files. Please stage the changes and commit again:"
	echo "  git add -u && git commit"
	exit 1
fi

make check || exit 1

make clippy || exit 1

exit 0
